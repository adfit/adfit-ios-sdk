{"abstract":[{"type":"text","text":"비즈보드 템플릿을 cell 형태로 제공하여 연동할 수 있는 방법을 소개합니다."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"이 문서는 UITableViewCell 형태로 비즈보트 템플릿을 연동하는 방법에 대해 담고 있습니다. UITableViewCell 형태의 레이아웃 구성을 제외하고는 ","type":"text"},{"identifier":"doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/BizBoardTemplate","type":"reference","isActive":true},{"type":"text","text":"과 동일하니, 다른 내용은 위 링크를 참고하시길 바랍니다."}]},{"anchor":"%EB%A0%88%EC%9D%B4%EC%95%84%EC%9B%83-%EA%B5%AC%EC%84%B1%ED%95%98%EA%B8%B0","level":2,"text":"레이아웃 구성하기","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"이 문서에선 UITableView에 대한 연동은 서비스의 구현 여부에 따라 다를 수 있기 때문에 다루지 않습니다."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"1-UITableView%EC%97%90-BizBoardCell-%EB%93%B1%EB%A1%9D","level":3,"text":"1. UITableView에 BizBoardCell 등록","type":"heading"},{"inlineContent":[{"type":"text","text":"사용할 UITableView에 AdFitSDK에서 제공하는 BizBoardCell 타입을 등록해 주세요."}],"type":"paragraph"},{"tabs":[{"title":"Swift","content":[{"code":["import UIKit","import AdFitSDK","","final class MyViewController: UIViewController {","    private let adCellIdentifier = \"BizBoardListFeedTableViewCell\"","    private let tableView = UITableView()","    ","    override func viewDidLoad() {","        super.viewDidLoad()","        ","        \/\/ ... 구현 생략 ...","        tableView.register(BizBoardCell.self, forCellReuseIdentifier: adCellIdentifier)","    }","}"],"syntax":"swift","type":"codeListing"}]},{"title":"Objective-C","content":[{"code":["#import \"MyViewController.h\"","#import <AdFitSDK\/AdFitSDK.h>","","@implementation MyViewController","","- (void)viewDidLoad {","    [super viewDidLoad];","    ","    \/\/ ... 구현 생략 ...","    [self.tableView registerClass:[BizBoardCell self] forCellReuseIdentifier: adCellIdentifier];","}","@end"],"type":"codeListing","syntax":"objective-c"}]}],"type":"tabNavigator"},{"anchor":"2-AdFitNativeAdLoaderDelegate-%EA%B5%AC%ED%98%84","level":3,"text":"2. AdFitNativeAdLoaderDelegate 구현","type":"heading"},{"inlineContent":[{"text":"광고 응답으로 받은 AdFitNativeAd를 property로 할당받고, 광고 응답이 왔을 경우, tableView를 reload 합니다. (loader의 호출 로직은 동일합니다.)","type":"text"}],"type":"paragraph"},{"tabs":[{"title":"Swift","content":[{"syntax":"swift","code":["import UIKit","import AdFitSDK","","final class MyViewController: UIViewController, AdFitNativeAdLoaderDelegate, \/*... 생략 ...*\/ {","    \/\/ ... property 생략 ...","    private var nativeAd: AdFitNativeAd?","    private var nativeAdLoader: AdFitNativeAdLoader?","    ","    \/\/ ... 구현 생략 ...","    ","    \/\/ MARK: - AdFitNativeAdLoaderDelegate","    func nativeAdLoaderDidReceiveAd(_ nativeAd: AdFitNativeAd) {","        self.nativeAd = nativeAd","        tableView.reloadData()","        print(\"광고 응답을 받았습니다.\")","    }","    ","    func nativeAdLoaderDidFailToReceiveAd(_ nativeAdLoader: AdFitNativeAdLoader, error: Error) {","        tableView.reloadData()","        print(\"광고 응답 에러: \\(error) (\\(error.localizedDescription))\")","    }","}"],"type":"codeListing"}]},{"title":"Objective-C","content":[{"type":"codeListing","code":["#import \"MyViewController.h\"","#import <AdFitSDK\/AdFitSDK.h>","","@implementation MyViewController","","#pragma mark - AdFitNativeAdLoaderDelegate","- (void)nativeAdLoaderDidReceiveAd:(AdFitNativeAd *)nativeAd {","    self.nativeAd = nativeAd;","    [self.tableView reloadData];","    NSLog(@\"광고 응답을 받았습니다.\");","}","","- (void)nativeAdLoaderDidFailToReceiveAd:(AdFitNativeAdLoader *)nativeAdLoader error:(NSError *)error {","    [self.tableView reloadData];","    NSLog(@\"광고 응답 에러: %@\", [error localizedDescription]);","}","","@end"],"syntax":"objective-c"}]}],"type":"tabNavigator"},{"anchor":"3-UITableViewDataSource-%EA%B5%AC%ED%98%84","level":3,"text":"3. UITableViewDataSource 구현","type":"heading"},{"inlineContent":[{"type":"text","text":"cellForRowAt function에서 "},{"type":"strong","inlineContent":[{"text":"adHeight(width: CGFloat)","type":"text"}]},{"type":"text","text":" function의 결과를 adHeight property에 저장합니다."}],"type":"paragraph"},{"tabs":[{"title":"Swift","content":[{"syntax":"swift","code":["import UIKit","import AdFitSDK","","final class MyViewController: UIViewController, \/*... 생략 ...*\/ {","    \/\/ ... property 생략 ...","    private var adHeight: CGFloat = 0","    ","    \/\/ ... 구현 생략 ...","    ","    \/\/ MARK: UITableViewDataSource","    ","    func tableView(_ tableView: UITableView, cellForRowAt indexPath: IndexPath) -> UITableViewCell {","        if let cell = tableView.dequeueReusableCell(withIdentifier: adCellName, for: indexPath) as? BizBoardCell {","            adHeight = cell.adHeight(width: view.bounds.width)","            \/\/ 광고뷰의 높이 저장","            return cell","        }","        ","        \/\/ ... service 구현 ...","    }","}"],"type":"codeListing"}]},{"title":"Objective-C","content":[{"syntax":"objective-c","code":["#import \"MyViewController.h\"","#import <AdFitSDK\/AdFitSDK.h>","","@implementation MyViewController","","\/\/ ... 구현 생략 ...","","#pragma mark - UITableViewDataSource","- (nonnull UITableViewCell *)tableView:(nonnull UITableView *)tableView cellForRowAtIndexPath:(nonnull NSIndexPath *)indexPath {","    BizBoardCell *cell = [tableView dequeueReusableCellWithIdentifier:adCellName forIndexPath:indexPath];","    if (cell) {","        self.adHeight = [cell adHeightWithWidth:self.view.bounds.size.width];","        return cell","    }","    ","    \/\/ ... service 구현 ...","}","@end"],"type":"codeListing"}]}],"type":"tabNavigator"},{"anchor":"4-UITableViewDelegate-%EA%B5%AC%ED%98%84","level":3,"text":"4. UITableViewDelegate 구현","type":"heading"},{"inlineContent":[{"type":"text","text":"과정 3에서 저장했던 "},{"type":"strong","inlineContent":[{"type":"text","text":"adHeight"}]},{"type":"text","text":" 값을 활용하여 cell의 높이를 설정하고, 과정 2에서 저장한 광고 응답인 "},{"type":"strong","inlineContent":[{"type":"text","text":"nativeAd"}]},{"type":"text","text":" property를 willDisplay 시점에 데이터를 맵핑합니다."}],"type":"paragraph"},{"tabs":[{"content":[{"code":["import UIKit","import AdFitSDK","","final class MyViewController: UIViewController, \/*... 생략 ...*\/ {","    \/\/ ... property 생략 ...","    private var adHeight: CGFloat = 0","    private var nativeAd: AdFitNativeAd?","    ","    \/\/ ... 구현 생략 ...","    ","    \/\/ MARK: UITableViewDelegate","    ","    func tableView(_ tableView: UITableView, willDisplay cell: UITableViewCell, forRowAt indexPath: IndexPath) {","        if let cell = cell as? BizBoardCell {","            if let nativeAd = nativeAd {","                nativeAd.bind(cell)","            }","        }","    }","    ","    func tableView(_ tableView: UITableView, heightForRowAt indexPath: IndexPath) -> CGFloat {","        return adHeight","    }","    ","    func tableView(_ tableView: UITableView, estimatedHeightForRowAt indexPath: IndexPath) -> CGFloat {","        return adHeight","    }"],"syntax":"swift","type":"codeListing"}],"title":"Swift"},{"content":[{"syntax":"objective-c","code":["#import \"MyViewController.h\"","#import <AdFitSDK\/AdFitSDK.h>","","@implementation MyViewController","","\/\/ ... 구현 생략 ...","","#pragma mark - UITableViewDelegate","","- (void)tableView:(UITableView *)tableView willDisplayCell:(UITableViewCell *)cell forRowAtIndexPath:(NSIndexPath *)indexPath {","    BizBoardCell *bizCell = (BizBoardCell *)cell;","    [self.nativeAd bind:bizCell];","}","","- (CGFloat)tableView:(UITableView *)tableView heightForRowAtIndexPath:(NSIndexPath *)indexPath {","    return self.adHeight;","}","","- (CGFloat)tableView:(UITableView *)tableView estimatedHeightForRowAtIndexPath:(NSIndexPath *)indexPath {","    return self.adHeight;","}","","@end"],"type":"codeListing"}],"title":"Objective-C"}],"type":"tabNavigator"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/adfitsdk\/bizboardtemplate+cell"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/AdFitSDK\/documentation\/AdFitSDK","doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/BizBoardTemplate"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/BizBoardTemplate+Cell"},"kind":"article","metadata":{"modules":[{"name":"AdFitSDK"}],"role":"article","images":[{"identifier":"banner-card.png","type":"card"},{"identifier":"iphone.png","type":"icon"}],"roleHeading":"Article","title":"비즈보드 템플릿 UITableViewCell 형태 지원"},"sections":[],"references":{"iphone.png":{"type":"image","alt":"A technology icon representing the SlothCreator framework.","variants":[{"url":"\/images\/AdFitSDK\/iphone.png","traits":["1x","light"]}],"identifier":"iphone.png"},"banner-card.png":{"type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/AdFitSDK\/banner-card@2x.png"}],"identifier":"banner-card.png","alt":"배너 광고 카드"},"doc://AdFitSDK/documentation/AdFitSDK":{"type":"topic","images":[{"identifier":"ad-icon.png","type":"icon"}],"title":"AdFitSDK","abstract":[{"type":"text","text":"AdFit SDK"}],"url":"\/documentation\/adfitsdk","role":"collection","identifier":"doc:\/\/AdFitSDK\/documentation\/AdFitSDK","kind":"symbol"},"ad-icon.png":{"identifier":"ad-icon.png","alt":"A technology icon representing the SlothCreator framework.","type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/AdFitSDK\/ad-icon@2x.png"}]},"doc://AdFitSDK/documentation/AdFitSDK/BizBoardTemplate":{"title":"비즈보드 템플릿 광고 연동","type":"topic","url":"\/documentation\/adfitsdk\/bizboardtemplate","role":"collectionGroup","images":[{"type":"card","identifier":"banner-card.png"},{"type":"icon","identifier":"iphone.png"}],"abstract":[{"text":"비즈보드 템플릿 광고 연동 과정을 소개합니다.","type":"text"}],"identifier":"doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/BizBoardTemplate","kind":"article"}}}