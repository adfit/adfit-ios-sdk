{"primaryContentSections":[{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"identifier":"bannerSample.jpg","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"해당 문서는 SwiftUI 사용자를 위한 문서이며, UIKit 사용자는 다른 문서를 참고하시길 바랍니다.","type":"text"}],"type":"paragraph"},{"anchor":"1-%EA%B4%91%EA%B3%A0-%EC%83%9D%EC%84%B1%ED%95%98%EA%B8%B0","level":2,"text":"1. 광고 생성하기","type":"heading"},{"type":"tabNavigator","tabs":[{"content":[{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AdFitSDK","","struct ContentView: View {","    var body: some View {","        AdFitBannerPresentableView(","            clientId: \"광고단위를 입력해 주세요.\",","            adUnitSize: \"320x50\"","        )","    }","}"]}],"title":"SwiftUI"}]},{"inlineContent":[{"text":"발급받은 광고 단위와 배너 사이즈를 입력하면, 광고 뷰가 생성됩니다.","type":"text"}],"type":"paragraph"},{"anchor":"2-operator-%EC%84%A4%EC%A0%95%ED%95%98%EA%B8%B0","level":2,"text":"2. operator 설정하기","type":"heading"},{"inlineContent":[{"type":"text","text":"제공되는 operator의 구현은 필수가 아닙니다. 해당 operator를 구현해서 광고로부터 발생하는 특정 이벤트를 감지하기 위해 제공됩니다."}],"type":"paragraph"},{"type":"tabNavigator","tabs":[{"content":[{"type":"codeListing","code":["public func onDidReceiveAd(_ closure: ((AdFitSDK.AdFitBannerAdView, (Error)?) -> Void)?) -> AdFitSDK.AdFitBannerPresentableView"],"syntax":"swift"}],"title":"SwiftUI"}]},{"columns":[{"size":1,"content":[{"inlineContent":[{"type":"text","text":"배너 광고 요청에 대한 응답이 왔을 때, 호출됩니다."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"parameter bannerAdView: 광고가 로드된 배너 광고 뷰 객체","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"parameter closure: 응답이 왔을 때, 호출되는 completion handler. (정상 응답 시, error는 nil)"}]}]}],"type":"unorderedList"}]}],"numberOfColumns":1,"type":"row"},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["public func onDidClickAd(_ closure: ((AdFitSDK.AdFitBannerAdView) -> Void)?) -> AdFitSDK.AdFitBannerPresentableView"]}]}]},{"columns":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"배너 광고에서 사용자 클릭이 발생하였을 때 호출됩니다."},{"type":"text","text":" "},{"type":"text","text":"클릭에 의해 광고주 페이지가 전체 화면으로 노출되므로, 화면 전환 시 필요한 동작이 있다면 이 메서드에 구현하세요."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"parameter closure: 클릭했을 때, 호출되는 completion handler.","type":"text"}]}]}]}],"size":1}],"numberOfColumns":1,"type":"row"},{"type":"tabNavigator","tabs":[{"content":[{"type":"codeListing","syntax":"swift","code":["public func onSizeThatFits(orientation: Binding<UIDeviceOrientation>, width: CGFloat) -> some View"]}],"title":"SwiftUI"}]},{"columns":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"배너 광고의 unitSize에 맞춰서 사이즈를 설정해 주는 operator 입니다."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"parameter orientation: 가로\/세로 모드 전환을 감지하기 위한 Binding","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"parameter width:","type":"text"},{"code":"AdFitBannerPresentableView","type":"codeVoice"},{"text":"의 width(미입력 시, 디바이스의 width로 설정됩니다.)","type":"text"}],"type":"paragraph"}]}]}],"size":1}],"numberOfColumns":1,"type":"row"},{"anchor":"3-%EC%82%AC%EC%9A%A9-%EC%98%88%EC%8B%9C-%EC%BD%94%EB%93%9C","level":2,"text":"3. 사용 예시 코드","type":"heading"},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AdFitSDK","","struct ContentView: View {","    @State private var orientation: UIDeviceOrientation = .unknown","    ","    var body: some View {","        AdFitBannerPresentableView(","            clientId: \"발급받은 광고 단위 ID를 입력해 주세요.\",","            adUnitSize: \"320x50\"","        )","        .onDidClickAd { _ in","            print(\"광고를 클릭했습니다.\")","        }","        .onDidReceiveAd { _, error in","            print(\"광고 응답을 받았습니다.\")","            if let error = error {","                print(\"광고 응답 에러: \\(error)\")","            }","        }","        .onSizeThatFits(orientation: $orientation)","    }","}"]}]}]},{"anchor":"4-%EC%97%90%EB%9F%AC-%EC%BD%94%EB%93%9C","level":2,"text":"4. 에러 코드","type":"heading"},{"inlineContent":[{"text":"광고 수신에 실패한 경우, ","type":"text"},{"code":"onDidReceiveAd","type":"codeVoice"},{"text":" 메서드를 통해 에러 객체를 전달받을 수 있습니다.","type":"text"},{"text":" ","type":"text"},{"text":"각각의 에러에 대한 설명은 아래 표를 참고해 주세요.","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"코드"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"메시지"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"설명"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"clientId property is nil","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"AdFitBannerAdView 객체에 clientId가 세팅되지 않은 경우.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"inlineContent":[{"text":"no ad to show","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"노출 가능한 광고가 없는 경우. 잠시 후 다시 광고 요청을 시도해 주세요.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"invalid ad received"}],"type":"paragraph"}],[{"inlineContent":[{"text":"유효하지 않은 광고를 받은 경우. AdFit에 문의해 주세요.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"inlineContent":[{"text":"failed to render ad","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"AdFitBannerAdView 객체의 사이즈가 기준 사이즈보다 작은 경우."}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"attempted to load ad too frequently","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"과도하게 짧은 시간 간격(30초 이내)으로 광고를 재요청한 경우.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"6"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"HTTP failed"}],"type":"paragraph"}],[{"inlineContent":[{"text":"HTTP 에러. 계속해서 반복 발생하는 경우 AdFit에 문의해 주세요.","type":"text"}],"type":"paragraph"}]]],"header":"row","alignments":["center","unset","unset"],"type":"table"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/AdFitSDK\/documentation\/AdFitSDK","doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/Simple+SwiftUI"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/adfitsdk\/swiftui+bannerad"]}],"identifier":{"url":"doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/SwiftUI+BannerAd","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"AdFitSDK"}],"roleHeading":"Article","images":[{"type":"card","identifier":"banner-card.png"},{"type":"icon","identifier":"iphone.png"}],"role":"article","title":"배너 광고 연동 for SwiftUI"},"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"abstract":[{"type":"text","text":"SwiftUI 사용자를 위한 배너 광고 연동에 대해 소개합니다."}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/AdFitSDK\/documentation\/AdFitSDK\/SwiftUI+BizBoardTemplate"]}],"references":{"bannerSample.jpg":{"alt":"배너샘플","type":"image","identifier":"bannerSample.jpg","variants":[{"traits":["1x","light"],"url":"\/images\/AdFitSDK\/bannerSample.jpg"}]},"iphone.png":{"alt":"A technology icon representing the SlothCreator framework.","identifier":"iphone.png","variants":[{"traits":["1x","light"],"url":"\/images\/AdFitSDK\/iphone.png"}],"type":"image"},"doc://AdFitSDK/documentation/AdFitSDK":{"type":"topic","images":[{"identifier":"ad-icon.png","type":"icon"}],"title":"AdFitSDK","abstract":[{"type":"text","text":"AdFit SDK"}],"url":"\/documentation\/adfitsdk","role":"collection","identifier":"doc:\/\/AdFitSDK\/documentation\/AdFitSDK","kind":"symbol"},"banner-card